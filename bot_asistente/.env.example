# ============================================================================
# María — Asistente de DT Growth Partners — variables de entorno (PLANTILLA)
# ============================================================================
# Copia este archivo a `.env` y rellena los valores marcados con ⬅️ PENDIENTE.
# ⚠️ NUNCA hagas commit del .env real. Está en .gitignore.
# ============================================================================

# ── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://maria_user:CHANGEME_PASSWORD@127.0.0.1:5432/maria_db
DATABASE_URL_SYNC=postgresql://maria_user:CHANGEME_PASSWORD@127.0.0.1:5432/maria_db

# ── ANTHROPIC (Claude API) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=                          # ⬅️ PENDIENTE
CLAUDE_MODEL_PRINCIPAL=claude-sonnet-4-6
CLAUDE_MODEL_INTENT=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS_OUTPUT=1024
# Provider: fallback (Dario + API directa) | dario | direct
CLAUDE_PROVIDER=fallback
DARIO_BASE_URL=http://127.0.0.1:3456
DARIO_API_KEY=dario

# ── WHAPI (número NUEVO de María) ───────────────────────────────────────────
WHAPI_BASE_URL=https://gate.whapi.cloud
WHAPI_TOKEN=                                # ⬅️ PENDIENTE (token del canal nuevo)
WHAPI_NUMERO_BOT=                           # ⬅️ PENDIENTE (+57... número nuevo de María)
WHAPI_WEBHOOK_SECRET=                       # ⬅️ generar: openssl rand -hex 32
WHAPI_WEBHOOK_URL=https://maria.dtgrowthpartners.com/webhook

# ── DT-OS (backend operativo DTGP) ──────────────────────────────────────────
DTOS_BASE_URL=https://os.dtgrowthpartners.com/api/webhook/bot
DTOS_API_KEY=                               # ⬅️ PENDIENTE (x-api-key ROTADA, no la vieja expuesta)

# ── MetaSuite (Meta Ads) ─────────────────────────────────────────────────────
METASUITE_BASE_URL=https://metasuite.dtgrowthpartners.com/api
METASUITE_TOKEN=                            # opcional según deploy

# ── Lead Radar ───────────────────────────────────────────────────────────────
LEADRADAR_BASE_URL=https://buscar.dtgrowthpartners.com

# ── Cal.com (agendamiento de prospectos, API v2) ────────────────────────────
CALCOM_BASE_URL=https://api.cal.com/v2
CALCOM_API_KEY=cal_live_xxx                 # personal API key (Bearer en v2)
CALCOM_EVENT_TYPE_ID=5551639                # event type "DTGP" (20 min, Cal Video)
CALCOM_WEBHOOK_SECRET=                       # ⬅️ generar: openssl rand -hex 32

# ── Fish Audio (voz de María: TTS responder + ASR transcribir) ──────────────
FISH_AUDIO_API_KEY=                         # ⬅️ key de Fish Audio
FISH_AUDIO_BASE_URL=https://api.fish.audio/v1
FISH_AUDIO_REFERENCE_ID=a0d3c07d5bc34713b967b0019c893695   # voz colombiana "María"
FISH_AUDIO_TTS_MODEL=s2-pro
FEATURE_TRANSCRIPCION_VOZ=true
FEATURE_RESPONDER_VOZ=true                  # si el prospecto manda voz, responder con voz
VOZ_IDIOMA=es
# Backend STT alternativo (Whisper-like) si no se usa Fish Audio:
VOZ_API_URL=
VOZ_API_KEY=

# ── Google Sheets (service account — finanzas; ROTAR la llave vieja) ────────
GOOGLE_SHEETS_CREDENTIALS_PATH=/home/maria/secrets/google_sheets_config.json

# ── EQUIPO DTGP ──────────────────────────────────────────────────────────────
DAIRO_PHONE=+573007189383                   # CEO — prioridad
STIVEN_PHONE=+573026444564                  # dueño técnico
EDGARDO_PHONE=+573116123189
JHONATHAN_PHONE=+573005033093

# ── ADMIN PANEL ──────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=                             # ⬅️ PENDIENTE
ADMIN_SESSION_SECRET=                       # ⬅️ generar: openssl rand -hex 32

# ── BOT (FastAPI) ──────────────────────────────────────────────────────────
BOT_HOST=127.0.0.1
BOT_PORT=8003
BOT_LOG_LEVEL=INFO
BOT_LOG_FILE=/home/maria/logs/maria.log
BOT_ENV=development                          # development | production

RATE_LIMIT_MENSAJES_POR_MINUTO_CLIENTE=10
RATE_LIMIT_OUTBOUND_POR_HORA=15

# ── HUMANIZACIÓN (anti-detección Meta) ──────────────────────────────────────
FEATURE_HUMANIZACION=true
HUMANIZATION_DELAY_MIN_S=20
HUMANIZATION_DELAY_MAX_S=60
HUMANIZATION_TYPING_INDICATOR=true
HORARIO_INICIO_HORA=8
HORARIO_FIN_HORA=22

# ── PATHS ─────────────────────────────────────────────────────────────────
DATA_DIR=/home/maria/data
PROMPTS_DIR=/home/maria/app/data/prompts

# ── FEATURE FLAGS ──────────────────────────────────────────────────────────
FEATURE_HUMAN_TAKEOVER=true

TZ=America/Bogota
