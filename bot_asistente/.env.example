# ============================================================================
# Bot Asistente — variables de entorno (PLANTILLA)
# ============================================================================
# Copia este archivo a `.env` y rellena los valores marcados con ⬅️ PENDIENTE.
# ⚠️ NUNCA hagas commit del .env real. Está en .gitignore.
# ============================================================================

# ── DATABASE ────────────────────────────────────────────────────────────────
# Producción (VPS): usuario Postgres = asistente_user (NO el usuario UNIX 'asistente').
# DB = asistente_db. Accesible solo desde 127.0.0.1.
DATABASE_URL=postgresql+asyncpg://asistente_user:CHANGEME_PASSWORD@127.0.0.1:5432/asistente_db
DATABASE_URL_SYNC=postgresql://asistente_user:CHANGEME_PASSWORD@127.0.0.1:5432/asistente_db

# ── ANTHROPIC (Claude API) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=                          # ⬅️ ver secrets/credenciales.md
CLAUDE_MODEL_PRINCIPAL=claude-sonnet-4-6
CLAUDE_MODEL_INTENT=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS_OUTPUT=1024
CLAUDE_MAX_CONVERSACIONES_POR_HORA=300

# ── WHAPI ──────────────────────────────────────────────────────────────────
WHAPI_BASE_URL=https://gate.whapi.cloud
WHAPI_TOKEN=                                # ⬅️ ver secrets/whapi.md
WHAPI_NUMERO_BOT=+573026041584
WHAPI_WEBHOOK_SECRET=                       # ⬅️ generamos: openssl rand -hex 32
WHAPI_WEBHOOK_URL=https://asistente.dtgrowthpartners.com/webhook

# ── SHOPIFY API PROPIA (la del bot anterior) ───────────────────────────────
SHOPIFY_API_BASE_URL=https://innova.dtgrowthpartners.com/api
SHOPIFY_API_KEY=a3f1b2c4-d5e6-7890-abcd-ef1234567890

# ── CATÁLOGO HTML PÚBLICO (segunda fuente) ─────────────────────────────────
CATALOGO_HTML_URL=https://innovacionfashion.co/pages/catalogo-de-whatsapp
CATALOGO_HTML_SYNC_INTERVAL_HORAS=12

# ── NÚMEROS DE TELÉFONO ────────────────────────────────────────────────────
ASISTENTE_PHONE_PRODUCCION=+573243798269    # línea futura cuando salgamos del nº de prueba
FABIO_PHONE=+573019836645                   # único destino de escalaciones
DUENO_PHONE_BLOCKED=+573206811130           # 🚫 BLOQUEO BIDIRECCIONAL

# ── BOT (FastAPI) ──────────────────────────────────────────────────────────
BOT_HOST=127.0.0.1                          # nginx hace reverse proxy desde 443
BOT_PORT=8003                               # ⚠️ FIJO 8003 — nginx ya apunta aquí
BOT_LOG_LEVEL=INFO
BOT_LOG_FILE=/home/asistente/logs/asistente.log
BOT_ENV=development                          # development | production

# Rate limits anti-bloqueo de Meta (ver INSTRUCCIONES_REENVIO_PEDIDOS.md)
RATE_LIMIT_MENSAJES_POR_MINUTO_CLIENTE=10
RATE_LIMIT_OUTBOUND_POR_HORA=15

# ── PATHS (VPS, usuario asistente) ─────────────────────────────────────────
DATA_DIR=/home/asistente/data
CATALOGO_DIR=/home/asistente/data/catalogo
PDFS_DIR=/home/asistente/data/pdfs
BANCOS_DIR=/home/asistente/data/mediosdepago
UBICACIONES_DIR=/home/asistente/data/ubicaciones
PROMPTS_DIR=/home/asistente/data/prompts
VOICE_MODULE_PYTHON=/home/asistente/data/voice_notes_module/speech_env/bin/python
VOICE_MODULE_SCRIPT=/home/asistente/data/voice_notes_module/audio_processor.py
VOICE_TIMEOUT_SEGUNDOS=60

# ── FEATURE FLAGS ──────────────────────────────────────────────────────────
FEATURE_SEGUIMIENTO_AUTO=false
FEATURE_ANALYTICS=false
FEATURE_HUMAN_TAKEOVER=true
FEATURE_AUDIO_TRANSCRIPCION=true
FEATURE_CATALOGO_HTML=true

TZ=America/Bogota
